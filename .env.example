# Database file path (relative or absolute)
SV_DB_PATH=data/stocks.db

# Telegram bot token and chat ID for price alerts
SV_TELEGRAM_BOT_TOKEN=
SV_TELEGRAM_CHAT_ID=

# How often to check alerts (in hours)
SV_ALERT_CHECK_HOURS=4

# Alert threshold relative to 200-week MA (in percent)
# 0 = alert at MA, +10 = 10% above MA, -10 = 10% below MA
SV_ALERT_THRESHOLD_PERCENT=0

# Server settings
SV_HOST=0.0.0.0
SV_PORT=8050
SV_DEBUG=false
